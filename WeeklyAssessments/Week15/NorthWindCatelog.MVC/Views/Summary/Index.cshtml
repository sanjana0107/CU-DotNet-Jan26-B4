@using NorthWindCatelog.MVC.DTOs
@model List<SummaryDto>

@{
    ViewData["Title"] = "Category Summary";
}

<h2 class="mb-4">Category Summary</h2>

<div class="table-responsive">
    <table class="table table-bordered table-striped">

        <thead class="table-dark">
            <tr>
                <th>Category</th>
                <th>Product Count</th>
                <th>Avg Price</th>
                <th>Most Expensive Product</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.CategoryName</td>
                    <td>@item.ProductCount</td>
                    <td>₹@item.AvgPrice.ToString("0.00")</td>
                    <td>@item.MostExpensiveProduct</td>
                </tr>
            }
        </tbody>

    </table>
</div>

<a href="@Url.Action("Index", "Categories")" class="btn btn-secondary mt-3">
    ← Back to Categories
</a>

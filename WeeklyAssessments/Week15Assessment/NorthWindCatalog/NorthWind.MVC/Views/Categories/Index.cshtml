@using NorthWind.Services.DTOs
@model IEnumerable<CategoryDto>

@{
    ViewData["Title"] = "Categories";
}

<h2 class="mb-4">Categories</h2>

<div class="row">
    @foreach (var item in Model)
    {
        <div class="col-md-4 mb-4">
            <div class="card shadow-sm h-100">
                <img src="@item.ImageUrl" class="card-img-top" style="height:200px; object-fit:cover;" />

                <div class="card-body text-center">
                    <h5 class="card-title">@item.CategoryName</h5>

                    <a href="/Products/ByCategory/@item.CategoryId"
                           class="btn btn-primary">
                        View Products
                    </a>
                </div>
            </div>
        </div>
    }
</div>
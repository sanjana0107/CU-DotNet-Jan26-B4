@model Week10Assessment.Models.Transaction

@{
    ViewData["Title"] = "Create Transaction";
}

<h1>Create Transaction</h1>

@* show chosen account info if available *@
@if (Model?.Account != null)
{
    <div class="mb-3">
        <strong>Account:</strong>
        Account Number: @Model.Account.AccountNumber
        &nbsp;|&nbsp;
        Name: @Model.Account.Name
    </div>
}

<h4>Transaction</h4>
<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group">
                <label asp-for="AccountId" class="control-label"></label>
                <select asp-for="AccountId" class="form-select" asp-items="ViewBag.AccountId">
                    <option value="">-- Select account --</option>
                </select>
                <span asp-validation-for="AccountId" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Description" class="control-label"></label>
                <input asp-for="Description" class="form-control" />
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Amount" class="control-label"></label>
                <input asp-for="Amount" class="form-control" type="number" step="0.01" />
                <span asp-validation-for="Amount" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Category" class="control-label"></label>
                <select asp-for="Category" class="form-select">
                    <option value="">-- Select --</option>
                    <option value="Debit">Debit</option>
                    <option value="Credit">Credit</option>
                </select>
                <span asp-validation-for="Category" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Date" class="control-label"></label>
                <input asp-for="Date" class="form-control" type="date" />
                <span asp-validation-for="Date" class="text-danger"></span>
            </div>

            <div class="form-group mt-3">
                <input type="submit" value="Create" class="btn btn-primary" />
                <a asp-controller="Account" asp-action="Index" class="btn btn-secondary ms-2">Back to Accounts</a>
            </div>
        </form>
    </div>
</div>




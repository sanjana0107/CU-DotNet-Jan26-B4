@page
@model LoginModel

@{
    ViewData["Title"] = "Login";
}

<style>
    html, body {
        height: 100%;
        margin: 0;
        padding: 0;
        overflow: hidden;
        position: relative;
        background-color: #F8F7FF;
    }

    header, footer {
        display: none !important;
    }

    .full-page {
        height: 100vh;
        width: 100%;
    }

    /* TOP BAR (LOGO + NAME) */
    .top-bar {
        position: absolute;
        top: 15px;
        left: 20px;
        display: flex;
        align-items: center;
        gap: 10px;
        z-index: 1000;
    }

    .logo {
        width: 40px;
        height: 40px;
        object-fit: contain;
    }

    .site-name {
        font-size: 20px;
        font-weight: bold;
        color: darkred;
    }

    /* LEFT PANEL */
    .left-panel {
        background: url('https://images.unsplash.com/photo-1503376780353-7e6692767b70') no-repeat center center;
        background-size: cover;
        height: 100%;
    }

    /* RIGHT PANEL */
    .right-panel {
        background-color: #F8F7FF;
        height: 100%;
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding: 50px;
        color: darkred;
    }

    .form-control {
        border-radius: 50px;
        padding: 12px 20px;
    }

    .btn-custom {
        border-radius: 50px;
        padding: 12px;
        font-weight: bold;
    }

    .container-fluid {
        padding-left: 0 !important;
        padding-right: 0 !important;
    }


    .brand-gradient {
        font-size: 26px;
        font-weight: bold;
        background: linear-gradient(to right, #ff0000, #8b0000);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }



    a {
        text-decoration: none;
    }
</style>

<div class="container-fluid full-page">

    <!-- TOP LEFT LOGO + NAME -->
    <div class="top-bar">
        <span class="brand-gradient">CarHub</span>
    </div>


    @* <div class="top-bar">
        <img src="https://cdn-icons-png.flaticon.com/512/744/744465.png" class="logo" />
        <span class="site-name">CarHub</span>
    </div> *@

    <div class="row h-100 g-0">

        <!-- LEFT PANEL -->
        <div class="col-md-6 left-panel d-none d-md-block"></div>

        <!-- RIGHT PANEL -->
        <div class="col-12 col-md-6 right-panel">

            <h3 class="mb-4">Welcome To CARHUB!</h3>

            <form method="post">

                <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

                <!-- Email -->
                <input asp-for="Input.Email"
                       type="email"
                       class="form-control mb-3"
                       placeholder="Enter Email" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>

                <!-- Password -->
                <input asp-for="Input.Password"
                       type="password"
                       class="form-control mb-3"
                       placeholder="Enter Password" />
                <span asp-validation-for="Input.Password" class="text-danger"></span>

                <!-- Button -->
                <button type="submit" class="btn btn-danger w-100 btn-custom mt-2">
                    Log in
                </button>

                <!-- Links -->
                <div class="mt-3 text-center">
                    <a asp-page="./Register" class="fw-semibold text-dark">
                        Create Account
                    </a>
                </div>

                <div class="text-center mt-2">
                    <a asp-page="./ForgotPassword" class="text-dark">
                        Forgot Password?
                    </a>
                </div>

            </form>

        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}




@model List<Employee>
@{
    ViewData["Title"] = "DashBoard";
}



<div class="alert alert-warning alert-dismissible fade show" role="alert">
    <strong>Department - @ViewData["deptName"]</strong>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
</div>

<div class="alert alert-success" role="alert">
    <h4 class="alert-heading">Daily Updates!</h4>
    <p>
        @ViewBag.announcement Welcome to today’s update! Our team is continuously working to improve this website so that visitors can
        enjoy a smoother and more helpful experience. Today we’ve made a few small improvements behind the scenes to 
        enhance speed, navigation, and overall performance. We are also reviewing and updating existing content to 
        ensure that everything remains accurate and useful for our readers. Your feedback and support help us keep 
        improving this platform every day. We encourage you to explore the website and check back regularly, as new 
        updates, features, and helpful information will continue to be added.
    </p>
</div>
@{
    if ((bool)ViewData["isActive"]!)
    {
        <div class="alert alert-success" role="alert">
           
            <p>
                Department is active.
                
            </p>
        </div>
        
    }
}
<table class="table table-striped table-bordered " >
    <thead class="table-dark">
        <tr>
            <th>Id</th>
            <th>Name</th>
            <th>Position</th>
            <th>Salary</th>
        </tr>
    </thead>
    <tbody>
        @{
            foreach (var item in Model)
            {
                <tr>
                <td>@item.EmployyeId</td>
                <td>@item.EmployeeName</td>
                <td>@item.Position</td>
                <td>@item.Salary</td>
                </tr>
            }
        }
    </tbody>    
</table>